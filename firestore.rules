rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for simulations collection
    match /simulations/{simId} {
      allow read, write: if true;
    }

    // Rules for social_posts collection
    match /social_posts/{postId} {
      allow read, write: if true;
    }

    // Rules for legislator_communications collection
    match /legislator_communications/{commId} {
      allow read, write: if true;
    }

    // Rules for chat_sessions collection
    match /chat_sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
