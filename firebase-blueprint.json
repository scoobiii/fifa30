{
  "entities": {
    "simulation": {
      "title": "Simulation",
      "description": "Simulation result of legislative voting",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "chamberVotes": { "type": "integer" },
        "senateVotes": { "type": "integer" },
        "timestamp": { "type": "string" }
      }
    },
    "social_post": {
      "title": "SocialPost",
      "description": "Social thread posts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "legislator_communication": {
      "title": "LegislatorCommunication",
      "description": "Messages sent to legislators",
      "type": "object",
      "properties": {
        "legislatorId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "subject": { "type": "string" },
        "messageContent": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "chat_session": {
      "title": "ChatSession",
      "description": "AI Agent Chat Session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "updatedAt": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" }
      }
    },
    "rag_document": {
      "title": "RagDocument",
      "description": "RAG knowledge base document for AI reasoning",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "system_config": {
      "title": "SystemConfig",
      "description": "System and agent prompts configuration",
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "simulations": {
      "schema": "simulation",
      "description": "Collection of legislative simulation states"
    },
    "social_posts": {
      "schema": "social_post",
      "description": "Collection of social posts and campaigns"
    },
    "legislator_communications": {
      "schema": "legislator_communication",
      "description": "Collection of citizen letters to legislators"
    },
    "chat_sessions": {
      "schema": "chat_session",
      "description": "Collection of saved chat sessions with AI Agents"
    },
    "rag_knowledge": {
      "schema": "rag_document",
      "description": "Collection of RAG knowledge base items"
    },
    "system_config": {
      "schema": "system_config",
      "description": "Collection for agent system prompts and system-level configuration"
    }
  }
}
